model Playlist {
    id                Int                        @id @default(autoincrement())
    title             String                     @db.VarChar(100)
    description       String?                    @db.VarChar(500)
    visibility        Visibility                 @default(private)
    cover             Image                      @relation(fields: [imageId], references: [id], onDelete: Cascade)
    imageId           Int
    createdAt         DateTime                   @default(now())
    updatedAt         DateTime                   @updatedAt
    createdExercises  Exercise[]                 @relation("Origin")
    includesExercises PlaylistIncludesExercise[]

    tags PlaylistTag[]

    author             User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
    authorId           Int
    userLikesPlaylists UserLikesPlaylist[]
}

model PlaylistIncludesExercise {
    exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
    exerciseId Int

    playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
    playlistId Int

    @@id([exerciseId, playlistId])
}

model PlaylistTag {
    id         Int      @id @default(autoincrement())
    label      String   @unique @db.VarChar(50)
    playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
    playlistId Int
}

enum Visibility {
    public
    private
}

model UserLikesPlaylist {
    user   User @relation(fields: [userId], references: [id])
    userId Int

    playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
    playlistId Int

    likedAt DateTime @default(now())

    @@id([userId, playlistId])
}
