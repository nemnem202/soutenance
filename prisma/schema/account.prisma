model User {
   id             Int      @id @default(autoincrement())
   email          String   @unique @db.VarChar(255)
   username       String   @unique @db.VarChar(20)
   createdAt      DateTime @default(now())
   updatedAt      DateTime @updatedAt
   profilePicture Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
   imageId        Int

   authMethods              AuthMethod[]
   classicAuthMethod        ClassicAuthMethod?
   exerciseSavesUserConfigs ExerciseSavesUserConfig[]
   playlists                Playlist[]
   exercises                Exercise[]
   likedPlaylists           UserLikesPlaylist[]
   likedExercises           UserLikesExercise[]
   likingUser               UserLikesUser[]           @relation("LikingUser")
   likedByUsers             UserLikesUser[]           @relation("LikedByUsers")
}

model ClassicAuthMethod {
   id        Int      @id @default(autoincrement())
   password  String   @db.VarChar(128)
   user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
   userId    Int      @unique
   createdAt DateTime @default(now())
}

model AuthMethod {
   id         Int          @id @default(autoincrement())
   provider   AuthProvider
   providerId String
   user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
   userId     Int
   createdAt  DateTime     @default(now())
}

enum AuthProvider {
   Google
}

model UserLikesUser {
   likedUser User @relation("LikedByUsers", fields: [likedId], references: [id], onDelete: Cascade)
   likedId   Int

   likingUser User @relation("LikingUser", fields: [likingId], references: [id], onDelete: Cascade)
   likingId   Int

   @@id([likedId, likingId])
}
